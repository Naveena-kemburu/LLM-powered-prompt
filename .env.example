# LLM Provider Configuration
# Choose: "openai" or "groq" (groq is FREE!)
LLM_PROVIDER=groq

# === GROQ (FREE) ===
# Get your FREE API key from: https://console.groq.com
# Free tier: 14,400 requests/day - Perfect for this project!
GROQ_API_KEY=your-groq-api-key-here

# === OpenAI (PAID) ===
# Get your API key from: https://platform.openai.com/api-keys
# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Specify the model to use
# For Groq: llama-3.3-70b-versatile, llama-3.1-70b-versatile, gemma2-9b-it
# For OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
LLM_MODEL=llama-3.3-70b-versatile

# Optional: Port for Flask application
# Default: 5000
PORT=5000
